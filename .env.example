# Copy this file to `.env` and fill in your OpenRouter key to enable live LLM
# rule-compilation in the RegWatch agent. Without it, RegWatch runs in offline
# (deterministic) mode and the rest of the app is unaffected.
#
# Get a free key at https://openrouter.ai/keys  (free models need only a free account)

OPENROUTER_API_KEY=

# Optional — override the default free model used by RegWatch.
# Any free model id from https://openrouter.ai/models?max_price=0 works, e.g.:
#   meta-llama/llama-3.3-70b-instruct:free
#   google/gemini-2.0-flash-exp:free
#   deepseek/deepseek-chat-v3-0324:free
#   qwen/qwen-2.5-72b-instruct:free
#   mistralai/mistral-small-3.1-24b-instruct:free
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
